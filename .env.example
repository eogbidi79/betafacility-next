# Postgres (Neon). Pooled = app runtime; direct = migrations.
DATABASE_URL=""
DIRECT_URL=""

# App
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Auth.js (portal login) ---
# Generate: `openssl rand -base64 32`
AUTH_SECRET=""
# Canonical public URL of the deployed app (fixes auth behind a proxy).
# Local: http://localhost:3000  ·  Production: https://www.betafacility.com
AUTH_URL="http://localhost:3000"
SEED_ADMIN_EMAIL="admin@betafacility.com"
SEED_ADMIN_PASSWORD=""
# Second admin (defaults to emmanuel.ogbidi@betafacility.com). If SEED_ADMIN2_PASSWORD
# is blank it reuses SEED_ADMIN_PASSWORD.
SEED_ADMIN2_EMAIL="emmanuel.ogbidi@betafacility.com"
SEED_ADMIN2_PASSWORD=""

# --- Payments (Paystack) ---
# TEST keys (sk_test_... / pk_test_...). Leave blank to use dev simulation mode.
PAYSTACK_SECRET_KEY=""
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=""

# --- Photo storage ---
# Preferred: Cloudflare R2 (server-side). Set all five to enable.
# R2_PUBLIC_URL is the bucket's public base (r2.dev domain or a custom domain).
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""
# Optional alternative: Cloudinary unsigned (client). Blank = inline fallback.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""

# --- Email notifications ---
# Add a Resend API key to send real emails; blank = log to server console (dev).
RESEND_API_KEY=""
EMAIL_FROM="BetaFacility Managers <info@betafacility.com>"
NOTIFY_CONTACT_TO="info@betafacility.com"
NOTIFY_SALES_TO="sales@betafacility.com"
NOTIFY_MAINTENANCE_TO="info@betafacility.com"
NOTIFY_PAYMENTS_TO="payments@betafacility.com"
NOTIFY_ADMIN_TO="admin@betafacility.com"
