// Prisma schema for BetaFacility Managers.
// Dev uses SQLite; for production swap `provider` to "postgresql" and point
// DATABASE_URL at Postgres/Supabase — the models below are portable.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  STAFF
  AGENT
  TENANT
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         Role     @default(TENANT)
  createdAt    DateTime @default(now())

  bookings Booking[]
}

/// Bookable short-let / long-term units (source of truth for availability).
model Rental {
  id            String  @id @default(cuid())
  slug          String  @unique
  title         String
  location      String
  description   String
  beds          Int?
  pricePerNight Int
  unitsTotal    Int     @default(1)
  image         String
  amenities     String // JSON-encoded string[]
  type          String // "short-term" | "long-term"
  bedroomClass  String // "studio" | "1-bed" | "2-bed" | "3-bed"
  active        Boolean @default(true)

  bookings Booking[]
}

enum BookingStatus {
  PENDING
  PAID
  SIGNED
  CANCELLED
}

model Booking {
  id       String @id @default(cuid())
  reference String @unique
  term     String @default("short-term") // "short-term" | "long-term"

  // Short-term stays reference a bookable Rental unit.
  rental   Rental? @relation(fields: [rentalId], references: [id])
  rentalId String?

  // Long-term tenancies snapshot the managed property + landlord at booking time.
  propertySlug    String?
  propertyTitle   String?
  propertyAddress String?
  landlordName    String?

  // Long-term application workflow:
  // APPLIED -> UNDER_REVIEW -> ACCEPTED (pay) | REJECTED
  stage             String?
  guarantorName     String?
  guarantorPhone    String?
  guarantorEmail    String?
  guarantorToken    String?   @unique
  guarantorConsent  Boolean   @default(false)
  guarantorConsentAt DateTime?

  guestName    String
  guestEmail   String
  guestPhone   String
  tenantAddress String?
  checkIn      DateTime
  checkOut     DateTime
  nights       Int
  amount       Int
  status       BookingStatus @default(PENDING)

  // Payment (Paystack)
  paymentRef String?
  paidAt     DateTime?

  // Tenant e-signature (data URL)
  signatureRef String?
  signedAt     DateTime?

  // Long-term tenancy: explicit inflation-clause consent + counter sign-offs
  inflationConsent   Boolean   @default(false)
  inflationConsentAt DateTime?
  repName            String?
  repSignedAt        DateTime?
  landlordSignedAt   DateTime?

  // Cancellation / refund (short-term)
  cancelledAt   DateTime?
  refundOutcome String? // "refundable" | "voucher" | "none"
  voucherCode   String? // voucher ISSUED when this booking was cancelled

  // Voucher REDEEMED against this booking
  appliedVoucherCode String?
  voucherDiscount    Int     @default(0)

  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  createdAt DateTime @default(now())
}

enum RequestStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model MaintenanceRequest {
  id          String        @id @default(cuid())
  reference   String        @unique
  kind        String        @default("report") // "report" | "booking"
  fullName    String
  email       String
  phone       String
  unit        String
  address     String?
  category    String?
  priority    String?
  service     String?
  preferredAt DateTime?
  description String?
  mediaCount  Int           @default(0)
  status      RequestStatus @default(NEW)
  createdAt   DateTime      @default(now())
}

enum ListingStatus {
  PENDING
  APPROVED
  REJECTED
}

model AdvertiseSubmission {
  id              String        @id @default(cuid())
  reference       String        @unique
  name            String
  email           String
  phone           String
  role            String
  propertyClass   String
  listingType     String
  transactionType String        @default("RENT") // RENT | SELL | BUY
  title           String
  category        String
  location        String
  price           Int
  description     String
  imageUrl        String?
  imageCount      Int           @default(0)
  // Displayed publicly only after an admin APPROVES it.
  status          ListingStatus @default(PENDING)
  createdAt       DateTime      @default(now())
}

model RentalListing {
  id             String   @id @default(cuid())
  title          String
  rentalCategory String // "Short-let" | "Long-Term" | "Sale"
  propertyType   String   @default("Apartment") // Studio|1-4+ Bedroom|Duplex|Detached|Semi-Detached|Townhouse|Condo|Apartment|Commercial|Land
  bedroomType    String // "Studio" | "1 Bedroom" | "2 Bedroom" | "3 Bedroom" | "4 Bedroom+"
  bathrooms      Int?
  totalUnits     Int      @default(1)
  availableUnits Int      @default(0)
  // Location (denormalised strings; country makes it multi-market)
  country        String   @default("Nigeria")
  state          String   @default("Lagos") // state / province / territory
  city           String   @default("Ajah")
  area           String?
  address        String?
  postalCode     String?
  price          Int? // short-let price per night
  rentPerYear    Int? // long-term rent per year
  currencyCode   String   @default("NGN") // NGN | CAD
  status         String   @default("Available") // "Coming Soon" | "Available" | "Fully Occupied"
  furnished      Boolean  @default(false)
  petFriendly    Boolean  @default(false)
  parking        Boolean  @default(false)
  amenities      String   @default("[]") // JSON string[]
  photos         String   @default("{}") // JSON { livingRoom, bedroom, toiletBathroom, kitchen, building: string[] }
  description    String?
  listedBy       String   @default("Beta Facility") // "Beta Facility" | "Agency" | "Individual"
  latitude       Float?
  longitude      Float?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

/// Agencies, property owners and service vendors that list on the platform.
/// One model with `kind` keeps the schema small; verification gates public display.
model Organization {
  id          String   @id @default(cuid())
  slug        String   @unique
  kind        String   @default("AGENCY") // AGENCY | OWNER | VENDOR
  name        String
  email       String?
  phone       String?
  country     String   @default("Nigeria")
  state       String?
  city        String?
  regNumber   String? // CAC number (NG) / business number (CA)
  logoUrl     String?
  website     String?
  description String?
  // Login that manages this organisation (matches a User.email).
  userEmail   String?
  verified    Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([kind, verified, active])
}

model Voucher {
  id             String    @id @default(cuid())
  code           String    @unique
  amount         Int
  guestEmail     String
  status         String    @default("ACTIVE") // ACTIVE | REDEEMED
  issuedForRef   String? // booking reference the voucher was issued from
  redeemedForRef String? // booking reference the voucher was redeemed on
  createdAt      DateTime  @default(now())
  redeemedAt     DateTime?
}

model ContactMessage {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  inquiryType String
  message     String
  handled     Boolean  @default(false)
  createdAt   DateTime @default(now())
}
